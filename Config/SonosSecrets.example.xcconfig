// Copy this file to SonosSecrets.xcconfig (same folder) and replace the placeholders.
// Register your integration at https://integration.sonos.com
//
//     cp SonosSecrets.example.xcconfig SonosSecrets.xcconfig
//
// Never commit SonosSecrets.xcconfig — it is listed in .gitignore.

SONOS_OAUTH_CLIENT_ID = YOUR_SONOS_CLIENT_ID
SONOS_OAUTH_CLIENT_SECRET = YOUR_SONOS_CLIENT_SECRET
SONOS_OAUTH_REDIRECT_URI = https://your-domain.example/oauth/callback.html
