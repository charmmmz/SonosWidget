<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>sonoswidget</string>
			</array>
			<key>CFBundleURLName</key>
			<string>com.charm.SonosWidget.oauth</string>
		</dict>
	</array>
	<key>SonosOAuthClientID</key>
	<string>$(SONOS_OAUTH_CLIENT_ID)</string>
	<key>SonosOAuthClientSecret</key>
	<string>$(SONOS_OAUTH_CLIENT_SECRET)</string>
	<key>SonosOAuthRedirectURI</key>
	<string>$(SONOS_OAUTH_REDIRECT_URI)</string>
	<key>BGTaskSchedulerPermittedIdentifiers</key>
	<array>
		<string>com.charm.SonosWidget.refresh</string>
	</array>
	<key>CADisableMinimumFrameDurationOnPhone</key>
	<true/>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>NSSupportsLiveActivities</key>
	<true/>
	<key>NSSupportsLiveActivitiesFrequentUpdates</key>
	<true/>
	<key>NSAppleMusicUsageDescription</key>
	<string>SonosWidget reads the Apple Music track currently playing on this iPhone so it can transfer playback to your selected Sonos speaker.</string>
	<key>NSLocalNetworkUsageDescription</key>
	<string>SonosWidget needs to access your local network to discover and control Sonos speakers.</string>
	<key>NSBonjourServices</key>
	<array>
		<string>_sonos._tcp</string>
	</array>
	<key>NSAppTransportSecurity</key>
	<dict>
		<key>NSAllowsLocalNetworking</key>
		<true/>
		<!-- NetEase Cloud Music serves album / artist artwork over plain HTTP
		     from *.music.126.net CDN hosts. Images only — no credentials or
		     personal data travel over these requests — so we scope the
		     exception tightly to the subdomain tree. -->
		<key>NSExceptionDomains</key>
		<dict>
			<key>music.126.net</key>
			<dict>
				<key>NSExceptionAllowsInsecureHTTPLoads</key>
				<true/>
				<key>NSIncludesSubdomains</key>
				<true/>
			</dict>
		</dict>
	</dict>
</dict>
</plist>
