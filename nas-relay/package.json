{
  "name": "sonos-live-activity-relay",
  "version": "0.1.0",
  "private": true,
  "description": "Subscribes to Sonos UPnP events and pushes Live Activity updates to the Charm for Sonos iOS app via APNs.",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "test": "node --import tsx --test \"src/**/*.test.ts\"",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts"
  },
  "dependencies": {
    "@parse/node-apn": "^8.1.0",
    "@svrooij/sonos": "^2.5.0",
    "express": "^4.21.0",
    "jpeg-js": "^0.4.4",
    "pino": "^9.5.0",
    "pino-http": "^10.3.0",
    "pngjs": "^7.0.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.17.0",
    "@types/pngjs": "^6.0.5",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=20"
  }
}
