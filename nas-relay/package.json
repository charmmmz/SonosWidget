{
  "name": "sonos-live-activity-relay",
  "version": "0.1.0",
  "private": true,
  "description": "Subscribes to Sonos UPnP events and pushes Live Activity updates to the SonosWidget iOS app via APNs.",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts"
  },
  "dependencies": {
    "@parse/node-apn": "^8.1.0",
    "@svrooij/sonos": "^2.5.0",
    "express": "^4.21.0",
    "pino": "^9.5.0",
    "pino-http": "^10.3.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.7.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=22"
  }
}
