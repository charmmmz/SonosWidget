# --- Shared (both containers on host network) ---
SONOS_SEED_IP=192.168.50.251
INTERNAL_API_TOKEN=generate-a-long-random-secret

# --- Node relay (nas-relay) ---
LOG_LEVEL=info
RELAY_PORT=8787
DATA_DIR=/app/data

APNS_BUNDLE_ID=com.charm.SonosWidget
APNS_KEY_PATH=/app/data/apns.p8
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_PRODUCTION=false

# --- Python agent (nas-agent) ---
AGENT_PORT=8790
NODE_BASE_URL=http://127.0.0.1:8787
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
AGENT_USER_TOKEN=another-secret-for-ios-app-bearer
DATABASE_PATH=/app/data/agent.db
HABIT_POLL_SECONDS=60
