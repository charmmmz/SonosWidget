# HTTP port (use host network — pick a free port on the NAS)
AGENT_PORT=8790

# OpenAI (tool-calling chat)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Must match the Node relay INTERNAL_API_TOKEN and base URL
NODE_BASE_URL=http://127.0.0.1:8787
INTERNAL_API_TOKEN=

# Clients (e.g. iOS app) send: Authorization: Bearer <this>
AGENT_USER_TOKEN=

# SQLite path inside container
DATABASE_PATH=/app/data/agent.db

# Poll Sonos groups every N seconds for habit logging (via Node internal API)
HABIT_POLL_SECONDS=60
